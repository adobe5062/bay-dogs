---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-cream/80 mt-20">
  <div class="max-w-5xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <p class="font-serif text-lg font-semibold text-cream mb-2">[Business Name]</p>
      <p class="text-sm leading-relaxed">Relationship coaching for you and your dog. Serving Maryland.</p>
    </div>
    <div>
      <p class="font-semibold text-cream mb-3 text-sm uppercase tracking-wide">Pages</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/about" class="hover:text-cream transition-colors">About</a></li>
        <li><a href="/services" class="hover:text-cream transition-colors">Services</a></li>
        <li><a href="/testimonials" class="hover:text-cream transition-colors">Testimonials</a></li>
        <li><a href="/contact" class="hover:text-cream transition-colors">Contact</a></li>
      </ul>
    </div>
    <div>
      <p class="font-semibold text-cream mb-3 text-sm uppercase tracking-wide">Connect</p>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="https://www.facebook.com/101004679563468" target="_blank" rel="noopener noreferrer" class="hover:text-cream transition-colors">
            Facebook
          </a>
        </li>
        <li>
          <a href="/contact" class="hover:text-cream transition-colors">Book a Free Consultation</a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-cream/10 text-center py-4 text-xs text-cream/40">
    &copy; {year} [Business Name]. All rights reserved.
  </div>
</footer>
