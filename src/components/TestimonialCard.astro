---
interface Props {
  clientName: string;
  dogName: string;
  body: string;
  photo?: string;
}

const { clientName, dogName, body, photo } = Astro.props;
---

<div class="bg-white rounded-lg p-8 shadow-sm border border-tan/20 flex flex-col gap-4">
  <svg class="w-8 h-8 text-tan flex-shrink-0" fill="currentColor" viewBox="0 0 32 32">
    <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H7.9C8.5 11.7 10 10 12 9.5L10 8zm12 0c-3.3 0-6 2.7-6 6v10h10V14h-6.1c.6-2.3 2.1-4 4.1-4.5L22 8z"/>
  </svg>
  <p class="text-charcoal/80 leading-relaxed italic flex-1">"{body}"</p>
  <div class="flex items-center gap-3 mt-2">
    {photo && (
      <img src={photo} alt={`${dogName}`} class="w-12 h-12 rounded-full object-cover border-2 border-tan/30" />
    )}
    <div>
      <p class="font-semibold text-charcoal text-sm">{clientName}</p>
      <p class="text-earthy-green text-sm">{dogName}</p>
    </div>
  </div>
</div>
