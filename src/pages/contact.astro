---
import Base from '../layouts/Base.astro';
---

<Base title="Contact">
  <div style="padding-top:108px;min-height:100vh;background:#faf8f4;">
    <div style="max-width:900px;margin:0 auto;padding:80px 40px;">
      <p style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;margin-bottom:12px;">Contact</p>
      <h1 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(32px,5vw,56px);color:#0d1b2a;margin-bottom:40px;">Get in touch.</h1>
      <form name="contact" method="POST" data-netlify="true" style="max-width:520px;">
        <input type="hidden" name="form-name" value="contact" />
        <div style="margin-bottom:18px;">
          <label style="display:block;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;color:#0d1b2a;margin-bottom:6px;">Your Name</label>
          <input type="text" name="name" required style="width:100%;padding:12px 16px;border-radius:10px;border:1.5px solid #e0ddd8;font-size:14px;outline:none;" />
        </div>
        <div style="margin-bottom:18px;">
          <label style="display:block;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;color:#0d1b2a;margin-bottom:6px;">Email</label>
          <input type="email" name="email" required style="width:100%;padding:12px 16px;border-radius:10px;border:1.5px solid #e0ddd8;font-size:14px;outline:none;" />
        </div>
        <div style="margin-bottom:24px;">
          <label style="display:block;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;color:#0d1b2a;margin-bottom:6px;">Message</label>
          <textarea name="message" rows="4" style="width:100%;padding:12px 16px;border-radius:10px;border:1.5px solid #e0ddd8;font-size:14px;outline:none;resize:vertical;"></textarea>
        </div>
        <button type="submit" style="padding:14px 32px;background:#f7941d;color:#fff;border:none;border-radius:10px;font-family:Montserrat,sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;">
          Send Message
        </button>
      </form>
    </div>
  </div>
</Base>
