---
interface Props {
  title: string;
  price: string;
  description: string;
  note?: string;
}

const { title, price, description, note } = Astro.props;
---

<div class="bg-white rounded-lg p-8 shadow-sm border border-tan/20 flex flex-col">
  <p class="text-earthy-green font-semibold text-sm uppercase tracking-wide mb-2">{price}</p>
  <h3 class="font-serif text-xl font-semibold text-charcoal mb-4">{title}</h3>
  <p class="text-charcoal/70 leading-relaxed flex-1">{description}</p>
  {note && <p class="mt-4 text-sm text-brown italic">{note}</p>}
  <a href="/contact" class="mt-6 inline-block text-center bg-earthy-green text-cream font-medium px-5 py-2.5 rounded hover:bg-earthy-green-dark transition-colors">
    Learn More
  </a>
</div>
