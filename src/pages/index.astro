---
import Base from '../layouts/Base.astro';

const services = [
  {
    name: 'Core Fundamentals Program',
    price: '$799',
    priceLabel: 'starting from',
    tag: 'Most Popular',
    accent: true,
    desc: 'Everything you need to begin transforming your relationship with your puppy or dog. Covers leadership, clear communication, boundary-setting, and motivating your dog through fun, engaging activities.',
    includes: ['Leadership & relationship-building','Boundary setting','Clear communication techniques','Fun, engaging training activities','Perfect for puppies & dogs without major behavioral issues'],
  },
  {
    name: 'Core Fundamentals + Behavior Modification',
    price: '$949',
    priceLabel: 'starting from',
    tag: 'Comprehensive',
    accent: false,
    desc: 'Everything in Core Fundamentals, plus specialized techniques addressing fear, anxiety, anti-social or reactive behavior toward other dogs or people.',
    includes: ['All Core Fundamentals content','Specialized behavioral techniques','Fear & anxiety management','Leash reactivity work','Anti-social behavior correction'],
  },
  {
    name: 'Single Lessons',
    price: '$175',
    priceLabel: 'per hour',
    tag: 'Returning Clients',
    accent: false,
    desc: "Fine-tune your dog's skills, brush up on your training, or teach your dog something new and fun. Available exclusively to clients who have completed a prior training program.",
    includes: ['Previous clients only','Fine-tune existing skills','Learn new tricks or skills','Refresher sessions','Flexible scheduling'],
  },
];

const testimonials = [
  {
    dog: 'Penny',
    breed: 'German Shepherd Puppy',
    owner: 'Felicity',
    quote: 'You are a miracle worker! We went from wrestling and being scratched to being able to quickly take control of the situation when Penny is feeling out of control and teach Penny how to calm herself. It has been a night and day difference.',
    detail: 'Penny was already a handful at 3 months old and was quickly getting out of hand as she grew to over 60 lbs by 6 months. We even got to take Penny to her first dog park, her first restaurant — and she behaved calmly the entire meal.',
  },
  {
    dog: 'Koda',
    breed: 'Mixed Breed, Age 3',
    owner: 'The Johnson Family',
    quote: 'She taught US how to support, reinforce, and correct his behaviors by providing us with the tools we needed to set him up for success. He is continuing to improve the more we practice what Lauren has taught us.',
    detail: "Koda used to be difficult to take on walks — impossible if I was pushing the stroller. Now I look forward to our morning walks every day as he stays right next to me and I don't have to worry about him taking off.",
  },
];

const pillars = [
  { icon: '🤝', title: 'Strong Relationship', desc: 'Built on trust and mutual respect between you and your dog.' },
  { icon: '💬', title: 'Clear Communication', desc: "Learn to speak your dog's language and be understood." },
  { icon: '🎯', title: 'Owner Commitment', desc: 'Long-term success depends on you — we coach both of you.' },
  { icon: '🎉', title: 'Actually Fun', desc: 'Training should be enjoyable — for you and your pup.' },
];

const skills = ['Puppy Training','House Training','Obedience','Behavior Modification','Separation Anxiety','Leash Reactivity','Senior Dog Training'];
const creds = ['IACP Member', 'AKC CGC Evaluator', 'Anne Arundel CC Instructor', 'Pet Therapy Training', 'Canine Body Language'];
---

<Base title="Relationship Coaching for You and Your Dog" description="Professional dog training. 15+ years experience. Free consultation.">

  <!-- BANNER -->
  <div style="position:fixed;top:0;left:0;right:0;z-index:1001;background:#f7941d;height:40px;overflow:hidden;display:flex;align-items:center;">
    <div class="banner-scroll" style="display:flex;white-space:nowrap;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;letter-spacing:0.8px;color:#fff;">
      <span style="padding-right:60px">✦ Visit the CONTACT section for a FREE phone consultation! &nbsp;✦&nbsp; Professional Dog Training &nbsp;✦&nbsp; Over 15 years of experience &nbsp;</span>
      <span style="padding-right:60px">✦ Visit the CONTACT section for a FREE phone consultation! &nbsp;✦&nbsp; Professional Dog Training &nbsp;✦&nbsp; Over 15 years of experience &nbsp;</span>
    </div>
  </div>

  <!-- NAVBAR -->
  <nav id="navbar" style="position:fixed;top:40px;left:0;right:0;z-index:1000;background:linear-gradient(to bottom,rgba(13,27,42,0.75) 0%,rgba(13,27,42,0) 100%);padding:0 clamp(16px,4vw,40px);height:68px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow 0.4s ease;">
    <a href="#home" class="nav-logo" style="cursor:pointer;text-decoration:none;">
      <svg width="48" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="22" cy="22" r="20" fill="#0d1b2a"/>
        <path d="M8 26 Q13 20 18 26 Q23 32 28 26 Q33 20 36 24" stroke="#2ec4e8" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <path d="M6 29 Q11 23 16 29 Q21 35 26 29 Q31 23 36 27" stroke="#1a9fc4" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>
        <circle cx="22" cy="13" r="6" fill="#f7941d"/>
        <path d="M22 4 L22 7" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M31 13 L28 13" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M29 7 L27 9" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M15 7 L17 9" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </a>

    <!-- Desktop links -->
    <div class="nav-desktop" style="display:flex;gap:4px;align-items:center;">
      {['home','about','trainer','services','testimonials','contact'].map((id) => (
        <button data-scroll={id} class="nav-link" style="background:none;border:none;cursor:pointer;padding:8px 14px;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.85);border-bottom:2px solid transparent;transition:all 0.2s;">
          {id === 'home' ? 'Home' : id === 'trainer' ? 'Meet the Trainer' : id.charAt(0).toUpperCase() + id.slice(1)}
        </button>
      ))}
      <button data-scroll="contact" class="pulse-glow" style="margin-left:12px;padding:10px 22px;background:#f7941d;color:#fff;border:none;border-radius:8px;font-family:Montserrat,sans-serif;font-weight:700;font-size:12px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;">
        Free Consult
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button id="hamburger" class="nav-mobile" style="background:none;border:none;cursor:pointer;padding:8px;display:flex;flex-direction:column;gap:5px;">
      <div class="bar" style="width:24px;height:2.5px;background:#fff;border-radius:2px;transition:all 0.3s;"></div>
      <div class="bar" style="width:24px;height:2.5px;background:#fff;border-radius:2px;transition:all 0.3s;"></div>
      <div class="bar" style="width:24px;height:2.5px;background:#fff;border-radius:2px;transition:all 0.3s;"></div>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;position:fixed;top:108px;left:0;right:0;background:#0d1b2a;padding:16px 0 24px;box-shadow:0 8px 32px rgba(0,0,0,0.4);z-index:999;flex-direction:column;align-items:stretch;">
    {['home','about','trainer','services','testimonials','contact'].map((id) => (
      <button data-scroll={id} class="mobile-nav-link" style="background:none;border:none;cursor:pointer;padding:14px 32px;text-align:left;font-family:Montserrat,sans-serif;font-weight:600;font-size:14px;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,0.8);border-left:3px solid transparent;transition:all 0.2s;">
        {id === 'home' ? 'Home' : id === 'trainer' ? 'Meet the Trainer' : id.charAt(0).toUpperCase() + id.slice(1)}
      </button>
    ))}
    <div style="padding:8px 32px 0;">
      <button data-scroll="contact" style="width:100%;padding:14px;background:#f7941d;color:#fff;border:none;border-radius:8px;font-family:Montserrat,sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;">
        Free Consultation
      </button>
    </div>
  </div>

  <!-- ══ HERO ══ -->
  <section id="home" style="position:relative;height:100vh;min-height:600px;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url(https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1800&auto=format&fit=crop);background-size:cover;background-position:center 30%;"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(120deg,rgba(13,27,42,0.88) 45%,rgba(13,27,42,0.35) 100%);"></div>

    <!-- Animated wave circles -->
    <div style="position:absolute;right:14%;bottom:15%;width:180px;height:180px;border-radius:50%;border:2px solid rgba(247,148,29,0.12);animation:waveFloat 4s ease-in-out infinite;"></div>
    <div style="position:absolute;right:20%;bottom:20%;width:360px;height:360px;border-radius:50%;border:2px solid rgba(247,148,29,0.09);animation:waveFloat 5s ease-in-out infinite;animation-delay:0.4s;"></div>
    <div style="position:absolute;right:26%;bottom:25%;width:540px;height:540px;border-radius:50%;border:2px solid rgba(247,148,29,0.06);animation:waveFloat 6s ease-in-out infinite;animation-delay:0.8s;"></div>

    <!-- Right panel image -->
    <div class="hero-right-panel" style="position:absolute;right:0;top:0;bottom:0;width:55%;">
      <div style="width:100%;height:100%;background-image:url(https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1200&auto=format&fit=crop);background-size:cover;background-position:center;clip-path:polygon(15% 0,100% 0,100% 100%,0% 100%);"></div>
    </div>

    <!-- Content -->
    <div class="animate-fadeUp hero-content" style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding-left:clamp(32px,8vw,120px);max-width:620px;">
      <span style="display:inline-block;padding:4px 14px;border-radius:99px;background:#f7941d;color:#fff;font-family:Montserrat,sans-serif;font-weight:600;font-size:11px;letter-spacing:1px;text-transform:uppercase;">Dog Training • Maryland</span>
      <h1 style="font-family:Montserrat,sans-serif;font-weight:900;font-size:clamp(42px,6vw,76px);line-height:1.05;color:#fff;margin-top:20px;margin-bottom:20px;">
        Relationship<br/>coaching for<br/><span style="color:#f7941d;">you &amp; your dog.</span>
      </h1>
      <p style="font-family:Inter,sans-serif;font-weight:300;font-size:18px;line-height:1.7;color:rgba(255,255,255,0.75);max-width:420px;margin-bottom:36px;">
        Strengthen your bond. Communicate clearly.<br/>Watch your dog thrive.
      </p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <button data-scroll="services" style="padding:16px 36px;background:#f7941d;color:#fff;border:none;border-radius:10px;font-family:Montserrat,sans-serif;font-weight:700;font-size:14px;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;transition:transform 0.2s,background 0.2s;">
          View Services
        </button>
        <button data-scroll="contact" style="padding:16px 36px;background:transparent;color:#fff;border:2px solid rgba(255,255,255,0.4);border-radius:10px;font-family:Montserrat,sans-serif;font-weight:700;font-size:14px;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;transition:border-color 0.2s,transform 0.2s;">
          Free Consultation
        </button>
      </div>

      <!-- Stats -->
      <div class="hero-stats" style="display:flex;gap:40px;margin-top:52px;">
        {[['15+','Years Experience'],['1,000+','Dogs Trained'],['100%','Owner Commitment']].map(([num, label]) => (
          <div>
            <div style="font-family:Montserrat,sans-serif;font-weight:800;font-size:28px;color:#f7941d;">{num}</div>
            <div style="font-family:Inter,sans-serif;font-size:12px;color:rgba(255,255,255,0.55);letter-spacing:0.5px;">{label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="animate-fadeIn" style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;">
      <span style="font-family:Montserrat,sans-serif;font-size:10px;letter-spacing:2px;color:rgba(255,255,255,0.4);text-transform:uppercase;">Scroll</span>
      <div style="width:24px;height:38px;border:2px solid rgba(255,255,255,0.3);border-radius:12px;display:flex;justify-content:center;padding-top:6px;">
        <div style="width:4px;height:8px;background:#f7941d;border-radius:2px;animation:fadeUp 1.2s ease infinite;"></div>
      </div>
    </div>
  </section>

  <!-- ══ ABOUT ══ -->
  <section id="about" style="background:#faf8f4;padding:100px 0;">
    <div style="max-width:1200px;margin:0 auto;padding:0 40px;">
      <div class="grid-2" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">
        <div class="reveal-left">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
            <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;">About Us</span>
          </div>
          <h2 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);line-height:1.1;color:#0d1b2a;margin-bottom:24px;">
            A dog training experience<br/><span style="color:#f7941d;">like no other.</span>
          </h2>
          <p style="font-size:16px;line-height:1.8;color:#444;margin-bottom:20px;">
            Training dogs is easy. <em>Maintaining the results</em> is the tricky part. Long-term success boils down to one important factor: <strong>YOU!</strong>
          </p>
          <p style="font-size:16px;line-height:1.8;color:#444;margin-bottom:32px;">
            We focus on the core fundamentals of owning a well-behaved dog. Once you and your dog are on the same page, you'll be able to transform their behavior with ease — and enjoy life with your dog to the fullest.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:10px;">
            {skills.map((s) => (
              <span style="display:inline-block;padding:4px 14px;border-radius:99px;background:rgba(247,148,29,0.12);color:#f7941d;font-family:Montserrat,sans-serif;font-weight:600;font-size:11px;letter-spacing:1px;text-transform:uppercase;">{s}</span>
            ))}
          </div>
        </div>

        <div class="reveal-right">
          <div style="position:relative;margin-bottom:32px;">
            <img src="https://images.unsplash.com/photo-1543466835-00a7907e9de1?w=700&auto=format&fit=crop" alt="Happy dog" style="width:100%;height:340px;object-fit:cover;border-radius:20px;display:block;" />
            <div style="position:absolute;bottom:-20px;right:-20px;background:#f7941d;color:#fff;border-radius:16px;padding:20px 24px;font-family:Montserrat,sans-serif;font-weight:800;font-size:22px;line-height:1.2;box-shadow:0 8px 32px rgba(247,148,29,0.4);">
              15+<br/><span style="font-size:11px;font-weight:600;letter-spacing:1px;">YEARS EXP.</span>
            </div>
          </div>
          <div class="pillar-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            {pillars.map((p) => (
              <div class="pillar-card" style="background:#fff;border-radius:14px;padding:20px;box-shadow:0 2px 16px rgba(0,0,0,0.06);border-top:3px solid #f7941d;transition:transform 0.2s;">
                <div style="font-size:24px;margin-bottom:8px;">{p.icon}</div>
                <div style="font-family:Montserrat,sans-serif;font-weight:700;font-size:14px;color:#0d1b2a;margin-bottom:6px;">{p.title}</div>
                <div style="font-size:13px;color:#666;line-height:1.5;">{p.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ MEET THE TRAINER ══ -->
  <section id="trainer" style="background:#0d1b2a;padding:100px 0;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-120px;top:-120px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(247,148,29,0.07) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="max-width:1200px;margin:0 auto;padding:0 40px;">
      <div class="grid-2" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">
        <div class="reveal-left" style="position:relative;">
          <div style="position:relative;">
            <img src="https://images.unsplash.com/photo-1601758124510-52d02ddb7cbd?w=800&auto=format&fit=crop&q=80" alt="Trainer with dog" style="width:100%;height:480px;object-fit:cover;object-position:top;border-radius:24px;display:block;" />
            <div class="trainer-frame" style="position:absolute;top:-16px;left:-16px;right:40px;bottom:40px;border-radius:28px;border:2px solid rgba(247,148,29,0.5);z-index:-1;"></div>
          </div>
        </div>
        <div class="reveal-right">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
            <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;">Meet the Trainer</span>
          </div>
          <h2 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(28px,3.5vw,46px);color:#fff;margin-bottom:8px;line-height:1.15;">[Trainer Name]</h2>
          <p style="font-family:Montserrat,sans-serif;font-weight:500;font-size:15px;color:#f7941d;margin-bottom:28px;letter-spacing:0.5px;">Owner &amp; Trainer</p>
          <p style="font-size:15px;line-height:1.85;color:rgba(255,255,255,0.72);margin-bottom:20px;">
            [Trainer] is the owner and trainer with <strong style="color:#fff;">over 15 years of experience</strong> in the dog training industry, having successfully trained thousands of dogs — and their owners — while addressing a wide array of behavioral issues.
          </p>
          <p style="font-size:15px;line-height:1.85;color:rgba(255,255,255,0.72);margin-bottom:20px;">
            There is one key factor to a dog's success at the heart of every case: <strong style="color:#f7941d;">owner commitment.</strong> By connecting with clients on a deeper level, [Trainer] can analyze their goals and customize an effective training plan that fits their lifestyle.
          </p>
          <p style="font-size:15px;line-height:1.85;color:rgba(255,255,255,0.55);margin-bottom:32px;">
            [Trainer bio details go here.]
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:10px;">
            {creds.map((c) => (
              <span style="padding:7px 16px;border:1.5px solid rgba(247,148,29,0.4);border-radius:99px;font-family:Montserrat,sans-serif;font-weight:600;font-size:11px;color:#f7941d;letter-spacing:0.8px;">{c}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ SERVICES ══ -->
  <section id="services" style="background:#fff8f0;padding:100px 0;">
    <div style="max-width:1200px;margin:0 auto;padding:0 40px;">
      <div class="reveal" style="text-align:center;margin-bottom:64px;">
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:16px;">
          <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
          <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;">What We Offer</span>
          <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
        </div>
        <h2 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);color:#0d1b2a;line-height:1.1;">Private Training Packages</h2>
        <p style="font-size:16px;color:#666;margin-top:16px;max-width:480px;margin-left:auto;margin-right:auto;">At-home training options tailored to you and your dog's unique needs.</p>
      </div>

      <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;align-items:start;">
        {services.map((s, i) => (
          <div class="reveal service-card" style={`transition-delay:${i*0.12}s;`}>
            <div style={`background:${s.accent ? '#0d1b2a' : '#fff'};border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.07);border:2px solid ${s.accent ? '#f7941d' : 'transparent'};transition:transform 0.35s ease,box-shadow 0.35s ease;`}>
              <div style="background:#f7941d;padding:10px 24px;display:flex;justify-content:space-between;align-items:center;">
                <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;color:#fff;letter-spacing:1.5px;text-transform:uppercase;">{s.tag}</span>
                <div style="background:rgba(255,255,255,0.25);border-radius:6px;padding:3px 10px;font-family:Montserrat,sans-serif;font-weight:800;font-size:16px;color:#fff;">
                  {s.price}<span style="font-size:10px;font-weight:600;"> / {s.priceLabel}</span>
                </div>
              </div>
              <div style="padding:28px 28px 32px;">
                <h3 style={`font-family:Montserrat,sans-serif;font-weight:800;font-size:18px;line-height:1.25;color:${s.accent ? '#fff' : '#0d1b2a'};margin-bottom:16px;`}>{s.name}</h3>
                <p style={`font-size:14px;line-height:1.75;color:${s.accent ? 'rgba(255,255,255,0.65)' : '#555'};margin-bottom:24px;`}>{s.desc}</p>
                <div style={`border-top:1px solid ${s.accent ? 'rgba(255,255,255,0.12)' : '#eee'};padding-top:20px;`}>
                  {s.includes.map((item) => (
                    <div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;">
                      <div style="width:18px;height:18px;border-radius:50%;background:#f7941d;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">
                        <svg width="10" height="8" viewBox="0 0 10 8"><path d="M1 4l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                      </div>
                      <span style={`font-size:13px;color:${s.accent ? 'rgba(255,255,255,0.7)' : '#555'};line-height:1.5;`}>{item}</span>
                    </div>
                  ))}
                </div>
                <button data-scroll="contact" style={`margin-top:24px;width:100%;padding:14px;background:${s.accent ? '#f7941d' : '#0d1b2a'};color:#fff;border:none;border-radius:10px;font-family:Montserrat,sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:opacity 0.2s;`}>
                  Get Started →
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ TESTIMONIALS ══ -->
  <section id="testimonials" style="background:#0d1b2a;padding:100px 0;position:relative;overflow:hidden;">
    <div style="position:absolute;left:-100px;bottom:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(247,148,29,0.06) 0%,transparent 70%);pointer-events:none;"></div>
    <div style="max-width:1100px;margin:0 auto;padding:0 40px;">
      <div class="reveal" style="text-align:center;margin-bottom:60px;">
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:16px;">
          <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
          <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;">Happy Clients</span>
          <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
        </div>
        <h2 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);color:#fff;line-height:1.1;">What families are saying</h2>
      </div>

      <div class="reveal" id="testimonial-panel" style="background:rgba(255,255,255,0.04);border-radius:24px;padding:56px 64px;border:1px solid rgba(255,255,255,0.08);display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;">
        {testimonials.map((t, i) => (
          <div class="testimonial-slide" data-index={i} style={i > 0 ? 'display:none;' : ''}>
            <div style="font-family:Georgia,serif;font-size:96px;line-height:0.8;color:#f7941d;opacity:0.3;margin-bottom:16px;">"</div>
            <blockquote style="font-family:Montserrat,sans-serif;font-weight:600;font-size:clamp(18px,2.2vw,26px);line-height:1.55;color:#fff;margin-bottom:24px;">
              {t.quote}
            </blockquote>
            <p style="font-size:14px;line-height:1.8;color:rgba(255,255,255,0.5);margin-bottom:32px;max-width:560px;">{t.detail}</p>
            <div style="display:flex;align-items:center;gap:16px;">
              <div style="width:48px;height:48px;border-radius:50%;background:#f7941d;display:flex;align-items:center;justify-content:center;font-family:Montserrat,sans-serif;font-weight:800;font-size:20px;color:#fff;">{t.dog[0]}</div>
              <div>
                <div style="font-family:Montserrat,sans-serif;font-weight:700;font-size:16px;color:#f7941d;">"{t.dog}"</div>
                <div style="font-size:13px;color:rgba(255,255,255,0.45);">{t.breed} · Owner: {t.owner}</div>
              </div>
            </div>
          </div>
        ))}
        <div>
          {testimonials.map((t, i) => (
            <img src={`https://images.unsplash.com/photo-${i === 0 ? '1589941013453-ec89f33b5e95' : '1558788353-f76d92427f16'}?w=400&auto=format&fit=crop`} alt={t.dog} class="testimonial-img" data-index={i} style={`width:220px;height:260px;object-fit:cover;border-radius:16px;display:${i > 0 ? 'none' : 'block'};`} />
          ))}
        </div>
      </div>

      <div style="display:flex;justify-content:center;gap:12px;margin-top:32px;">
        {testimonials.map((_, i) => (
          <button class="dot-btn" data-index={i} style={`width:${i === 0 ? '32' : '10'}px;height:10px;border-radius:5px;background:${i === 0 ? '#f7941d' : 'rgba(255,255,255,0.25)'};border:none;cursor:pointer;transition:all 0.3s ease;padding:0;`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ CONTACT ══ -->
  <section id="contact" style="background:#faf8f4;padding:100px 0;">
    <div style="max-width:1100px;margin:0 auto;padding:0 40px;">
      <div class="grid-2" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;">
        <!-- Left -->
        <div class="reveal-left">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <div style="width:32px;height:3px;background:#f7941d;border-radius:2px;"></div>
            <span style="font-family:Montserrat,sans-serif;font-weight:700;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#f7941d;">Get In Touch</span>
          </div>
          <h2 style="font-family:Montserrat,sans-serif;font-weight:800;font-size:clamp(28px,3.5vw,46px);color:#0d1b2a;line-height:1.15;margin-bottom:20px;">
            Ready to start your<br/><span style="color:#f7941d;">journey together?</span>
          </h2>
          <p style="font-size:16px;line-height:1.8;color:#555;margin-bottom:40px;">
            The first step is a free phone consultation. Let's talk about your goals, your dog's challenges, and how we can help.
          </p>
          {[
            { icon: '📍', label: 'Location', value: '[Your Location]' },
            { icon: '📱', label: 'Facebook', value: '[Facebook URL]' },
            { icon: '🎓', label: 'Credentials', value: 'IACP Member · AKC CGC Evaluator' },
          ].map((item) => (
            <div style="display:flex;gap:16px;align-items:flex-start;margin-bottom:24px;">
              <div style="width:44px;height:44px;border-radius:12px;background:rgba(247,148,29,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">{item.icon}</div>
              <div>
                <div style="font-family:Montserrat,sans-serif;font-weight:700;font-size:12px;color:#0d1b2a;letter-spacing:1px;text-transform:uppercase;margin-bottom:2px;">{item.label}</div>
                <div style="font-size:14px;color:#666;">{item.value}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Form -->
        <div class="reveal-right">
          <form id="contact-form" name="contact" method="POST" data-netlify="true" style="background:#fff;border-radius:20px;padding:44px 40px;box-shadow:0 4px 40px rgba(0,0,0,0.08);">
            <input type="hidden" name="form-name" value="contact" />
            <div style="font-family:Montserrat,sans-serif;font-weight:800;font-size:20px;color:#0d1b2a;margin-bottom:28px;">Free Consultation Request</div>
            {[
              { name: 'name', label: 'Your Name', type: 'text', placeholder: 'Jane Smith' },
              { name: 'email', label: 'Email Address', type: 'email', placeholder: 'jane@email.com' },
              { name: 'phone', label: 'Phone Number', type: 'tel', placeholder: '(410) 555-0000' },
              { name: 'dog', label: "Dog's Name & Breed", type: 'text', placeholder: 'Max, Golden Retriever' },
            ].map((f) => (
              <div style="margin-bottom:18px;">
                <label style="display:block;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;color:#0d1b2a;letter-spacing:0.5px;margin-bottom:6px;">{f.label}</label>
                <input type={f.type} name={f.name} placeholder={f.placeholder} style="width:100%;padding:12px 16px;border-radius:10px;border:1.5px solid #e0ddd8;font-size:14px;font-family:Inter,sans-serif;outline:none;transition:border-color 0.2s;background:#fafafa;" />
              </div>
            ))}
            <div style="margin-bottom:24px;">
              <label style="display:block;font-family:Montserrat,sans-serif;font-weight:600;font-size:12px;color:#0d1b2a;letter-spacing:0.5px;margin-bottom:6px;">Tell us about your goals</label>
              <textarea name="message" placeholder="What would you like to work on with your dog?" rows="4" style="width:100%;padding:12px 16px;border-radius:10px;border:1.5px solid #e0ddd8;font-size:14px;font-family:Inter,sans-serif;resize:vertical;outline:none;transition:border-color 0.2s;background:#fafafa;"></textarea>
            </div>
            <button type="submit" style="width:100%;padding:16px;background:#f7941d;color:#fff;border:none;border-radius:10px;font-family:Montserrat,sans-serif;font-weight:700;font-size:14px;letter-spacing:1.2px;text-transform:uppercase;cursor:pointer;transition:background 0.2s;">
              Request Free Consultation →
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FOOTER ══ -->
  <footer style="background:#060f18;padding:40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;">
    <svg width="48" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="22" cy="22" r="20" fill="#0d1b2a"/>
      <path d="M8 26 Q13 20 18 26 Q23 32 28 26 Q33 20 36 24" stroke="#2ec4e8" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <path d="M6 29 Q11 23 16 29 Q21 35 26 29 Q31 23 36 27" stroke="#1a9fc4" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>
      <circle cx="22" cy="13" r="6" fill="#f7941d"/>
      <path d="M22 4 L22 7" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M31 13 L28 13" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M29 7 L27 9" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M15 7 L17 9" stroke="#f7941d" stroke-width="1.5" stroke-linecap="round"/>
      <text x="48" y="17" font-family="Montserrat,sans-serif" font-weight="800" font-size="12" fill="#0d1b2a" letter-spacing="2">BAY</text>
      <text x="48" y="32" font-family="Montserrat,sans-serif" font-weight="800" font-size="12" fill="#f7941d" letter-spacing="2">DOGS</text>
    </svg>
    <div style="font-family:Inter,sans-serif;font-size:13px;color:rgba(255,255,255,0.35);">
      © 2025 [Business Name]
    </div>
    <a href="#" rel="noreferrer" style="width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.55);text-decoration:none;font-family:Montserrat,sans-serif;font-weight:800;font-size:14px;transition:all 0.2s;">f</a>
  </footer>

<style>
@media (max-width: 768px) {
  /* Hero */
  .hero-right-panel { display: none !important; }
  .hero-content {
    padding-left: 24px !important;
    padding-right: 24px !important;
    max-width: 100% !important;
  }
  .hero-stats { gap: 20px !important; flex-wrap: wrap !important; }

  /* Grids → single column */
  .grid-2 { grid-template-columns: 1fr !important; gap: 36px !important; }
  .grid-3 { grid-template-columns: 1fr !important; gap: 20px !important; }
  .pillar-grid { gap: 12px !important; }

  /* Trainer accent frame causes overflow on mobile */
  .trainer-frame { display: none !important; }

  /* Testimonial panel */
  #testimonial-panel {
    grid-template-columns: 1fr !important;
    padding: 32px 24px !important;
    gap: 0 !important;
  }
  #testimonial-panel img { display: none !important; }

  /* Section vertical padding */
  #about, #trainer, #services, #testimonials, #contact {
    padding: 60px 0 !important;
  }

  /* Section inner horizontal padding */
  #about > div,
  #trainer > div,
  #services > div,
  #testimonials > div,
  #contact > div { padding-left: 20px !important; padding-right: 20px !important; }

  /* Services section has two inner divs — target the grid wrapper */
  #services > div > div:first-child { margin-bottom: 40px; }
}
</style>

</Base>

<script>
  // Scroll-to-section
  document.querySelectorAll('[data-scroll]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.scroll!;
      const el = document.getElementById(id);
      if (el) {
        const top = el.getBoundingClientRect().top + window.scrollY - 108;
        window.scrollTo({ top, behavior: 'smooth' });
      }
      // close mobile menu
      const menu = document.getElementById('mobile-menu');
      if (menu) menu.style.display = 'none';
    });
  });

  // Navbar scroll solidify
  const navbar = document.getElementById('navbar')!;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar.style.background = '#0d1b2a';
      navbar.style.boxShadow = '0 2px 24px rgba(0,0,0,0.3)';
    } else {
      navbar.style.background = 'linear-gradient(to bottom,rgba(13,27,42,0.75) 0%,rgba(13,27,42,0) 100%)';
      navbar.style.boxShadow = 'none';
    }
  });

  // Hamburger menu
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  hamburger.addEventListener('click', () => {
    const open = mobileMenu.style.display === 'flex';
    mobileMenu.style.display = open ? 'none' : 'flex';
  });

  // Scroll reveal
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => obs.observe(el));

  // Service card hover
  document.querySelectorAll('.service-card > div').forEach(card => {
    card.addEventListener('mouseenter', () => {
      (card as HTMLElement).style.transform = 'translateY(-8px)';
      (card as HTMLElement).style.boxShadow = '0 20px 60px rgba(0,0,0,0.15)';
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = '';
      (card as HTMLElement).style.boxShadow = '0 4px 24px rgba(0,0,0,0.07)';
    });
  });

  // Pillar card hover
  document.querySelectorAll('.pillar-card').forEach(card => {
    card.addEventListener('mouseenter', () => (card as HTMLElement).style.transform = 'translateY(-3px)');
    card.addEventListener('mouseleave', () => (card as HTMLElement).style.transform = '');
  });

  // Testimonials carousel
  const slides = document.querySelectorAll('.testimonial-slide');
  const imgs = document.querySelectorAll('.testimonial-img');
  const dots = document.querySelectorAll('.dot-btn');
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const i = parseInt((dot as HTMLElement).dataset.index!);
      slides.forEach((s, j) => (s as HTMLElement).style.display = j === i ? 'block' : 'none');
      imgs.forEach((img, j) => (img as HTMLElement).style.display = j === i ? 'block' : 'none');
      dots.forEach((d, j) => {
        (d as HTMLElement).style.width = j === i ? '32px' : '10px';
        (d as HTMLElement).style.background = j === i ? '#f7941d' : 'rgba(255,255,255,0.25)';
      });
    });
  });

  // Form input focus glow
  document.querySelectorAll('#contact-form input, #contact-form textarea').forEach(el => {
    el.addEventListener('focus', () => (el as HTMLElement).style.borderColor = '#f7941d');
    el.addEventListener('blur', () => (el as HTMLElement).style.borderColor = '#e0ddd8');
  });
</script>
